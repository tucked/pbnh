{% set read_only = url is defined and url is not none %}
<!DOCTYPE html>
<html>
    <head>
        <title>pbnh</title>
        <style>
            html, body {
                background-color: #272822;  /* Make the background match codemirror-theme-monokai. */
                color: white;
                height: 100%;
                margin: 0;
            }
            body {
                display: flex;
            }
            main {
                position: relative;
                flex: 1;
            }
            #loading {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                pointer-events: none;
            }
            #toolbar {
                display: flex;
                flex-direction: column;
                gap: 1rem;
                list-style: none;
                margin: 0;
                padding: 1rem;
            }
            #toolbar a, #toolbar button {
                background: none;
                border: 0;
                padding: 0;
                cursor: pointer;
                text-decoration: none;
            }
            .icon {
                width: 1.5rem;
                height: 1.5rem;
                display: inline-block;
                vertical-align: middle;
                filter: invert(1);
            }
            .spin {
                animation: spin 1s linear infinite;
                transform-origin: center;
            }
            @keyframes spin {
                from { transform: rotate(0deg); }
                to { transform: rotate(360deg); }
            }
        </style>
    </head>
    <body>
        <main>
            <img id="loading" class="icon spin" src="{{ url_for('static', filename='dist/lucide/icons/loader.svg') }}" alt="">
        </main>
        <ul id="toolbar">
            <li>
                <a id="about" href="/about" title="About">
                    <img class="icon" src="{{ url_for('static', filename='dist/lucide/icons/circle-help.svg') }}" alt="">
                </a>
            </li>
            <li>
                <a id="new" href="/" title="New Paste">
                    <img class="icon" src="{{ url_for('static', filename='dist/lucide/icons/file-plus.svg') }}" alt="">
                </a>
            </li>
            {%- if not read_only %}
            <li>
                <button id="redirect" type="button" title="Save as Redirect">
                    <img class="icon" src="{{ url_for('static', filename='dist/lucide/icons/external-link.svg') }}" alt="">
                </button>
            </li>
            <li>
                <button id="save" type="button" title="Save (ctrl+s)">
                    <img class="icon" src="{{ url_for('static', filename='dist/lucide/icons/save.svg') }}" alt="">
                </button>
            </li>
            {%- endif %}
        </ul>
        <script type="module">
            import { PbnhEditor } from "{{ url_for('static', filename='dist/pbnh-editor.js') }}";

            window.editor = new PbnhEditor({
                parent: document.querySelector("main"),
                {%- if read_only %}
                readOnly: true,
                {%- else %}
                onKeyDown: (event) => {
                    if ((event.ctrlKey || event.metaKey) && event.key === "s") {
                        event.preventDefault();
                        document.getElementById("save").click();
                    }
                },
                {%- endif %}
            });

            {%- if read_only %}
            fetch("{{ url }}")
                .then(response => {
                    const filename = new URL(response.url).pathname;
                    const mime = (response.headers.get("Content-Type") || "").split(";")[0].trim();
                    window.editor.setLanguage(filename, mime);
                    return response.text();
                })
                .then(doc => {
                    window.editor.setValue(doc);
                    document.getElementById("loading").remove();
                });
            {%- else %}
            window.editor.focus();

            function savePaste(key) {
                const form = new FormData();
                form.append(key, window.editor.getValue());
                fetch("/", { method: "POST", body: form })
                    .then(response => response.ok ? response.text() : "")
                    .then(text => { if (text) window.location.href = JSON.parse(text).link + ".txt"; });
            }

            document.getElementById("redirect").addEventListener("click", () => {
                const url = window.editor.getValue().trim();
                if (!url) {
                    alert("Please enter a URL to redirect to.");
                    return;
                }
                try {
                    new URL(url);
                } catch {
                    alert("The redirect URL does not appear to be valid.");
                    return;
                }
                if (confirm("Create a paste that redirects to the URL below?\n\n" + url)) {
                    savePaste("redirect");
                }
            });
            document.getElementById("save").addEventListener("click", () => savePaste("content"));

            document.getElementById("loading").remove();
            {%- endif %}
        </script>
    </body>
</html>
