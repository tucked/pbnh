{% set read_only = url is defined and url is not none %}
<!DOCTYPE html>
<html>
    <head>
        <title>pbnh</title>
        <style>
            html, body {
                background-color: #272822;  /* Make the background match codemirror-theme-monokai. */
                color: white;
                height: 100%;
                margin: 0;
            }
            body {
                display: flex;
            }
            main {
                flex: 1;
            }
            #loading-message {
                font-family: sans-serif;
                text-align: center;
            }
            #toolbar {
                display: flex;
                flex-direction: column;
                gap: 1rem;
                list-style: none;
                margin: 0;
                padding: 1rem;
            }
            #toolbar li {
                cursor: pointer;
            }
        </style>
        <link rel="stylesheet" href="{{ url_for('static', filename='dist/font-awesome/css/font-awesome.min.css') }}">
    </head>
    <body>
        <main>
            <p id="loading-message">loading...</p>
        </main>
        <ul id="toolbar">
            <li id="helpicon" title="About"><span class="fa fa-question fa-lg"></span></li>
            <li id="newicon" title="New Paste"><span class="fa fa-file-o fa-lg"></span></li>
            {%- if not read_only %}
            <li id="redirecticon" title="Save as Redirect"><span class="fa fa-external-link fa-lg"></span></li>
            <li id="saveicon" title="Save (ctrl+s)"><span class="fa fa-save fa-lg"></span></li>
            {%- endif %}
        </ul>
        <script type="module">
            import { createEditor } from "{{ url_for('static', filename='dist/pbnh-editor.js') }}";

            window.editor = createEditor({
                parent: document.querySelector("main"),
                url: {{ url|default('')|tojson }},
                {%- if not read_only %}
                onKeyDown: (event) => {
                    if ((event.ctrlKey || event.metaKey) && event.key === "s") {
                        event.preventDefault();
                        saveicon.click();
                    }
                },
                {%- endif %}
                onLoad: () => { document.getElementById("loading-message").remove(); },
            });
            window.editor.focus();

            // Toolbar
            helpicon.addEventListener("click", () => window.location.href = "/about");
            newicon.addEventListener("click", () => window.location.href = "/");
            {%- if not read_only %}

            function savePaste(key) {
                var xhttp = new XMLHttpRequest();
                xhttp.onreadystatechange = function() {
                    if (xhttp.readyState == 4 && xhttp.status == 201 && xhttp.responseText.length) {
                        window.location.href = JSON.parse(xhttp.responseText).link + ".txt";
                    }
                };
                var myForm = new FormData();
                myForm.append(key, window.editor.getValue());
                xhttp.open("POST", "/");
                xhttp.send(myForm);
            }

            redirecticon.addEventListener("click", () => {
                const url = window.editor.getValue().trim();
                if (!url) {
                    alert("Please enter a URL to redirect to.");
                    return;
                }
                try {
                    new URL(url);
                } catch {
                    alert("The redirect URL does not appear to be valid.");
                    return;
                }
                if (confirm("Create a paste that redirects to the URL below?\n\n" + url)) {
                    savePaste("redirect");
                }
            });
            saveicon.addEventListener("click", () => savePaste("content"));
            {%- endif %}
        </script>
    </body>
</html>
