{% set read_only = url is defined and url is not none %}
<!DOCTYPE html>
<html>
    <head>
        <title>pbnh</title>
        <style>
            html, body {
                background-color: #272822;  /* Make the background match codemirror-theme-monokai. */
                color: white;
                height: 100%;
                margin: 0;
            }
            body {
                display: flex;
            }
            main {
                position: relative;
                flex: 1;
            }
            #loading {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                pointer-events: none;
            }
            #toolbar {
                display: flex;
                flex-direction: column;
                gap: 1rem;
                list-style: none;
                margin: 0;
                padding: 1rem;
            }
            #toolbar li {
                cursor: pointer;
            }
        </style>
        <link rel="stylesheet" href="{{ url_for('static', filename='dist/font-awesome/css/fontawesome.min.css') }}">
        <link rel="stylesheet" href="{{ url_for('static', filename='dist/font-awesome/css/solid.min.css') }}">
        <link rel="stylesheet" href="{{ url_for('static', filename='dist/font-awesome/css/regular.min.css') }}">
    </head>
    <body>
        <main>
            <span id="loading" class="fa-solid fa-spinner fa-lg"></span>
        </main>
        <ul id="toolbar">
            <li id="about" title="About"><span class="fa-solid fa-question fa-lg"></span></li>
            <li id="new" title="New Paste"><span class="fa-regular fa-file fa-lg"></span></li>
            {%- if not read_only %}
            <li id="redirect" title="Save as Redirect"><span class="fa-solid fa-arrow-up-right-from-square"></span></li>
            <li id="save" title="Save (ctrl+s)"><span class="fa-solid fa-floppy-disk"></span></li>
            {%- endif %}
        </ul>
        <script type="module">
            import { PbnhEditor } from "{{ url_for('static', filename='dist/pbnh-editor.js') }}";

            window.editor = new PbnhEditor({
                parent: document.querySelector("main"),
                url: {{ url|default('')|tojson }},
                {%- if not read_only %}
                onKeyDown: (event) => {
                    if ((event.ctrlKey || event.metaKey) && event.key === "s") {
                        event.preventDefault();
                        document.getElementById("save").click();
                    }
                },
                {%- endif %}
                onLoad: () => { document.getElementById("loading").remove(); },
            });
            window.editor.focus();

            // Toolbar
            document.getElementById("about").addEventListener("click", () => window.location.href = "/about");
            document.getElementById("new").addEventListener("click", () => window.location.href = "/");
            {%- if not read_only %}

            function savePaste(key) {
                var xhttp = new XMLHttpRequest();
                xhttp.onreadystatechange = function() {
                    if (xhttp.readyState == 4 && xhttp.status == 201 && xhttp.responseText.length) {
                        window.location.href = JSON.parse(xhttp.responseText).link + ".txt";
                    }
                };
                var myForm = new FormData();
                myForm.append(key, window.editor.getValue());
                xhttp.open("POST", "/");
                xhttp.send(myForm);
            }

            document.getElementById("redirect").addEventListener("click", () => {
                const url = window.editor.getValue().trim();
                if (!url) {
                    alert("Please enter a URL to redirect to.");
                    return;
                }
                try {
                    new URL(url);
                } catch {
                    alert("The redirect URL does not appear to be valid.");
                    return;
                }
                if (confirm("Create a paste that redirects to the URL below?\n\n" + url)) {
                    savePaste("redirect");
                }
            });
            document.getElementById("save").addEventListener("click", () => savePaste("content"));
            {%- endif %}
        </script>
    </body>
</html>
